/// Lightweight daily counter for unauthenticated guest endpoints that incur
/// billed AI-provider calls (e.g. guest ATS scoring).  Keyed on the hashed IP
/// so raw IPs are never stored.  The @@unique makes Postgres upsert atomic.
model guestUsage {
  id        Int      @id @default(autoincrement())
  ipHash    String
  date      DateTime @db.Date
  count     Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([ipHash, date])
  @@index([date])
}

/// Indian higher-education institutions from the AISHE (All India Survey on
/// Higher Education) directory, seeded from data/aishe-colleges.csv. Backs the
/// college autocomplete on the student profile page. Name search uses a
/// pg_trgm GIN index (added in the migration) for fast ILIKE '%term%' lookups.
model college {
  id        Int     @id @default(autoincrement())
  aisheCode String
  name      String
  state     String
  district  String?

  @@index([state])
}
