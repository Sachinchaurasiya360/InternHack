model jobIndex {
  id              Int           @id @default(autoincrement())
  sourceType      JobSourceType
  sourceId        Int
  title           String
  company         String
  location        String
  salary          String?
  salaryMin       Int?
  salaryMax       Int?
  description     String
  tags            String[]      @default([])
  skills          String[]      @default([])
  experienceLevel String?
  workMode        String?
  domain          String?
  applicationUrl  String?
  deadline        DateTime?
  isActive        Boolean       @default(true)
  isEnriched      Boolean       @default(false)
  hasEmbedding    Boolean       @default(false)
  lastEnrichedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  matches         jobMatch[]

  @@unique([sourceType, sourceId])
  @@index([isActive])
  @@index([isActive, createdAt])
  @@index([workMode])
  @@index([experienceLevel])
  @@index([domain])
  @@index([isEnriched])
  @@index([hasEmbedding])
}

model userJobPreference {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  desiredRoles     String[] @default([])
  desiredSkills    String[] @default([])
  desiredLocations String[] @default([])
  minSalary        Int?
  workMode         String[] @default([])
  experienceLevel  String[] @default([])
  domains          String[] @default([])
  profileSkills    String[] @default([])
  profileSummary   String?
  viewedJobIds     Int[]    @default([])
  appliedJobIds    Int[]    @default([])
  dismissedJobIds  Int[]    @default([])
  savedJobIds      Int[]    @default([])
  hasEmbedding     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             user     @relation("UserJobPreferences", fields: [userId], references: [id], onDelete: Cascade)
}

model applicationProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  preferredName      String?
  legalName          String?
  phoneCountryCode   String?
  address            Json     @default("{}")
  education          Json     @default("[]")
  experience         Json     @default("[]")
  workAuthorization  Json     @default("{}")
  demographics       Json     @default("{}")
  availability       Json     @default("{}")
  salaryExpectations Json     @default("{}")
  links              Json     @default("{}")
  customFields       Json     @default("{}")
  autofillSettings   Json     @default("{}")
  privacySettings    Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               user     @relation("UserApplicationProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model applicationQuestionAnswer {
  id                 Int      @id @default(autoincrement())
  userId             Int
  questionText       String
  normalizedQuestion String
  answer             String
  category           String?
  source             String   @default("USER")
  lastUsedAt         DateTime?
  useCount           Int      @default(0)
  embedding          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               user     @relation("UserApplicationQuestionAnswers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedQuestion])
  @@index([userId])
  @@index([normalizedQuestion])
  @@index([userId, category])
}

model trackedJobApplication {
  id                Int                      @id @default(autoincrement())
  userId            Int
  sourceType        TrackedApplicationSource @default(MANUAL)
  sourceId          Int?
  jobIndexId        Int?
  adminJobId        Int?
  scrapedJobId      Int?
  company           String
  role              String
  location          String?
  jobUrl            String?
  applicationUrl    String?
  jobDescription    String?
  status            TrackedApplicationStatus @default(SAVED)
  appliedAt         DateTime?
  deadline          DateTime?
  nextFollowUpAt    DateTime?
  resumeUrl         String?
  coverLetterId     Int?
  notes             String                   @default("")
  contacts          Json                     @default("[]")
  events            Json                     @default("[]")
  extensionMetadata Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              user                     @relation("UserTrackedJobApplications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([jobIndexId])
  @@index([adminJobId])
  @@index([scrapedJobId])
}

model extensionAutofillEvent {
  id            Int                    @id @default(autoincrement())
  userId        Int
  applicationId Int?
  host          String
  siteType      String?
  urlHash       String?
  eventType     ExtensionAutofillEventType
  fieldCount    Int                    @default(0)
  filledCount   Int                    @default(0)
  failedCount   Int                    @default(0)
  metadata      Json                   @default("{}")
  createdAt     DateTime               @default(now())
  user          user                   @relation("UserExtensionAutofillEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([host])
  @@index([eventType])
}

model jobMatch {
  id            Int      @id @default(autoincrement())
  userId        Int
  jobIndexId    Int
  score         Float
  skillMatch    Float    @default(0)
  locationMatch Float    @default(0)
  salaryMatch   Float    @default(0)
  vectorScore   Float    @default(0)
  seen          Boolean  @default(false)
  dismissed     Boolean  @default(false)
  saved         Boolean  @default(false)
  applied       Boolean  @default(false)
  createdAt     DateTime @default(now())
  jobIndex      jobIndex @relation(fields: [jobIndexId], references: [id], onDelete: Cascade)
  user          user     @relation("UserJobMatches", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobIndexId])
  @@index([userId, score])
  @@index([userId, seen, dismissed])
  @@index([createdAt])
}

model jobAgentConversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  messages  Json     @default("[]")
  context   Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation("UserAgentConversations", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model generatedResume {
  id             Int      @id @default(autoincrement())
  userId         Int
  title          String   @default("Untitled Resume")
  jobTitle       String?
  jobDescription String?
  keySkills      String?
  latexContent   String
  source         String   @default("AI_GENERATED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           user     @relation("UserGeneratedResumes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model generatedCoverLetter {
  id             Int      @id @default(autoincrement())
  studentId      Int
  jobTitle       String?
  companyName    String?
  jobDescription String
  content        String
  tone           String
  useProfile     Boolean  @default(false)
  keySkills      String?
  excerpt        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        user     @relation("StudentCoverLetters", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
}

enum JobSourceType {
  INTERNAL
  SCRAPED
  ADMIN
}

enum TrackedApplicationSource {
  INTERNHACK_ADMIN
  SCRAPED
  JOB_INDEX
  EXTENSION
  MANUAL
}

enum TrackedApplicationStatus {
  SAVED
  APPLIED
  OA
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
  GHOSTED
}

enum ExtensionAutofillEventType {
  DETECTED
  AUTOFILLED
  FIELD_FAILED
  QUESTION_GENERATED
  TRACKED
  SUPPORT_REQUESTED
}
