// ============================================================
// TALENT POOL MODELS
// ============================================================

model talentPool {
  id          Int                @id @default(autoincrement())
  recruiterId Int
  recruiter   user               @relation("RecruiterTalentPools", fields: [recruiterId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  members talentPoolMember[]

  @@index([recruiterId])
}

model talentPoolMember {
  id        Int        @id @default(autoincrement())
  poolId    Int
  pool      talentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  studentId Int
  student   user       @relation("TalentPoolMemberships", fields: [studentId], references: [id], onDelete: Cascade)
  notes     String?
  addedAt   DateTime   @default(now())

  @@unique([poolId, studentId])
  @@index([poolId])
  @@index([studentId])
}

// ============================================================
// CAMPUS DRIVE MODELS
// ============================================================

model campusDrive {
  id                      Int                      @id @default(autoincrement())
  recruiterId             Int
  recruiter               user                     @relation("RecruiterCampusDrives", fields: [recruiterId], references: [id], onDelete: Cascade)
  title                   String
  description             String
  company                 String
  targetColleges          String[]                 @default([])
  eligibleBranches        String[]                 @default([])
  minCGPA                 Float?
  eligibleGraduationYears Int[]                    @default([])
  registrationDeadline    DateTime
  driveDate               DateTime?
  status                  CampusDriveStatus        @default(DRAFT)
  jobIds                  Int[]                    @default([])
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  registrations campusDriveRegistration[]

  @@index([recruiterId])
  @@index([status])
  @@index([registrationDeadline])
}

model campusDriveRegistration {
  id           Int                      @id @default(autoincrement())
  driveId      Int
  drive        campusDrive              @relation(fields: [driveId], references: [id], onDelete: Cascade)
  studentId    Int
  student      user                     @relation("StudentCampusRegistrations", fields: [studentId], references: [id], onDelete: Cascade)
  status       CampusRegistrationStatus @default(REGISTERED)
  registeredAt DateTime                 @default(now())

  @@unique([driveId, studentId])
  @@index([driveId])
  @@index([studentId])
}

// ============================================================
// AI SERVICE CONFIG & REQUEST LOG
// ============================================================

model aiServiceConfig {
  id        Int            @id @default(autoincrement())
  service   AIServiceType  @unique
  provider  AIProviderType @default(GEMINI)
  modelName String         @default("gemini-2.5-flash-lite")
  updatedAt DateTime       @updatedAt

  requestLogs aiRequestLog[]
}

model aiRequestLog {
  id              Int              @id @default(autoincrement())
  serviceConfigId Int
  serviceConfig   aiServiceConfig  @relation(fields: [serviceConfigId], references: [id], onDelete: Cascade)
  service         AIServiceType
  providerName    AIProviderType
  modelName       String
  latencyMs       Int
  inputTokens     Int?
  outputTokens    Int?
  success         Boolean          @default(true)
  errorMessage    String?
  userId          Int?
  createdAt       DateTime         @default(now())

  @@index([providerName, createdAt])
  @@index([service, createdAt])
  @@index([createdAt])
}

